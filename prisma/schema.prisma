generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Feed {
  id          String   @id @default(cuid())
  source      String   // "x" | "threads" | "rss" | "github"
  sourceUrl   String
  authorName  String?
  authorHandle String?
  content     String
  summary     String?
  urlHash      String?
  repoUrl      String?
  repoName     String?
  repoStars    Int?
  repoLanguage String?
  repoReadme   String?
  isRead       Boolean  @default(false)
  isBookmarked Boolean @default(false)
  notionPageId String?
  collectedAt DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([source, sourceUrl])
  @@index([urlHash])
  @@index([collectedAt(sort: Desc)])
  @@index([source])
}
